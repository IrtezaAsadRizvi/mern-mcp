export async function update{{entityName}}(request{{#if isTypeScript}}: Request{{/if}}, response{{#if isTypeScript}}: Response{{/if}}) {
  const updated = await {{names.singularCamel}}Service.update{{entityName}}(request.params.id, request.body);

  if (!updated) {
    response.status(404).json({
      message: "{{entityName}} not found"
    });
    return;
  }

  response.json(updated);
}

export async function delete{{entityName}}(request{{#if isTypeScript}}: Request{{/if}}, response{{#if isTypeScript}}: Response{{/if}}) {
  const deleted = await {{names.singularCamel}}Service.delete{{entityName}}(request.params.id);

  if (!deleted) {
    response.status(404).json({
      message: "{{entityName}} not found"
    });
    return;
  }

  response.status(204).send();
}
