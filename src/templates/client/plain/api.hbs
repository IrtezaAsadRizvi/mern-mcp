{{#if isTypeScript}}
import type { {{entityName}}, {{formValuesName}} } from "../types/{{names.singularKebab}}.types";
{{/if}}

const BASE_URL = "{{apiBasePath}}";

async function request(path{{#if isTypeScript}}: string{{/if}}, init{{#if isTypeScript}}: RequestInit = {}{{/if}}) {
  const response = await fetch(`${BASE_URL}${path}`, {
    headers: {
      "Content-Type": "application/json",
      ...(init.headers ?? {})
    },
    ...init
  });

  if (!response.ok) {
    throw new Error(`Request failed with status ${response.status}`);
  }

  if (response.status === 204) {
    return null;
  }

  return response.json();
}

export async function list{{names.pluralPascal}}(){{#if isTypeScript}}: Promise<{{entityName}}[]>{{/if}} {
  return request("/");
}

export async function get{{entityName}}(id{{#if isTypeScript}}: string{{/if}}){{#if isTypeScript}}: Promise<{{entityName}}>{{/if}} {
  return request(`/${id}`);
}

export async function create{{entityName}}(
  payload{{#if isTypeScript}}: {{formValuesName}}{{/if}}
){{#if isTypeScript}}: Promise<{{entityName}}>{{/if}} {
  return request("/", {
    method: "POST",
    body: JSON.stringify(payload)
  });
}

export async function update{{entityName}}(
  id{{#if isTypeScript}}: string{{/if}},
  payload{{#if isTypeScript}}: {{formValuesName}}{{/if}}
){{#if isTypeScript}}: Promise<{{entityName}}>{{/if}} {
  return request(`/${id}`, {
    method: "PUT",
    body: JSON.stringify(payload)
  });
}

export async function delete{{entityName}}(id{{#if isTypeScript}}: string{{/if}}){{#if isTypeScript}}: Promise<void>{{/if}} {
  await request(`/${id}`, {
    method: "DELETE"
  });
}
