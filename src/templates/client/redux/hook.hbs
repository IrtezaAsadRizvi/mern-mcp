  fetch{{entityName}}Thunk,
  fetch{{names.pluralPascal}}Thunk,
  initial{{entityName}}State,
  update{{entityName}}Thunk,
  {{names.singularCamel}}StoreKey
} from "../api/{{names.singularKebab}}.api";

export function use{{entityName}}() {
  const dispatch = useDispatch{{#if isTypeScript}}<any>{{/if}}();
  const state = useSelector((rootState{{#if isTypeScript}}: Record<string, typeof initial{{entityName}}State>{{/if}}) => {
    return rootState[{{names.singularCamel}}StoreKey] ?? initial{{entityName}}State;
