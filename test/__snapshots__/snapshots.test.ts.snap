    {
      "action": "create",
      "content": "import React, { useEffect, useState } from "react";
import type { Order } from "../types/order.types";
import { orderFieldConfig } from "../types/order.types";
import { useOrder } from "../hooks/useOrder";

function renderFieldValue(value: unknown) {
  if (Array.isArray(value)) {
    return value.join(", ");
  }

  if (typeof value === "boolean") {
    return value ? "Yes" : "No";
  }

  return value ? String(value) : "—";
}

export interface OrderDetailProps {
  id?: string;
  item?: Order | null;
  onEdit?: (item: Order) => void;
}

export function OrderDetail({ id, item, onEdit }: OrderDetailProps) {
  const { loadItem, isLoading, error } = useOrder();
  const [resolvedItem, setResolvedItem] = useState(item ?? null);

  useEffect(() => {
    setResolvedItem(item ?? null);
  }, [item]);

  useEffect(() => {
    if (!id) {
      return;
    }

    void loadItem(id).then((nextItem) => {
      setResolvedItem(nextItem);
    });
  }, [id]);

  if (!resolvedItem && isLoading) {
    return <p>Loading Order...</p>;
  }

  if (!resolvedItem) {
    return <p>No Order selected.</p>;
  }

  return (
    <section>
      <h2>Order details</h2>
      {error ? <p role="alert">{String(error)}</p> : null}
      <dl>
        {orderFieldConfig.map((field) => (
          <React.Fragment key={field.key}>
            <dt>{field.label}</dt>
            <dd>{renderFieldValue(resolvedItem[field.key])}</dd>
          </React.Fragment>
        ))}
      </dl>
      <button type="button" onClick={() => onEdit?.(resolvedItem)}>
        Edit
      </button>
    </section>
  );
}

export default OrderDetail;
