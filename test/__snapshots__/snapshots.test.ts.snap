    {
      "action": "create",
      "content": "import React, { useEffect, useState } from "react";
import {
  inventoryItemFieldConfig,
  inventoryItemInitialValues,
} from "../types/inventory-item.types";
import { useInventoryItem } from "../hooks/useInventoryItem";

function getFieldValue(value) {
  if (Array.isArray(value)) {
    return value.join(", ");
  }

  return value ?? "";
}

export function InventoryItemForm({ value, onSuccess }) {
  const { createItem, updateItem, isLoading, error } = useInventoryItem();
  const [formValues, setFormValues] = useState(() => ({
    ...inventoryItemInitialValues,
    ...(value ?? {}),
  }));

  useEffect(() => {
    setFormValues({
      ...inventoryItemInitialValues,
      ...(value ?? {}),
    });
  }, [value]);

  const handleFieldChange = (fieldKey, nextValue) => {
    setFormValues((current) => ({
      ...current,
      [fieldKey]: nextValue,
    }));
  };

  const handleSubmit = async (event) => {
    event.preventDefault();

    const saved = value?._id
      ? await updateItem(value._id, formValues)
      : await createItem(formValues);

    if (!value?._id) {
      setFormValues({ ...inventoryItemInitialValues });
    }

    onSuccess?.(saved);
  };

  return (
    <form onSubmit={handleSubmit}>
      <h2>{value?._id ? "Edit InventoryItem" : "Create InventoryItem"}</h2>
      {error ? <p role="alert">{String(error)}</p> : null}
      {inventoryItemFieldConfig.map((field) => {
        const currentValue = formValues[field.key];

        if (field.widget === "textarea") {
          return (
            <label key={field.key}>
              <span>{field.label}</span>
              <textarea
                value={String(getFieldValue(currentValue))}
                onChange={(event) => handleFieldChange(field.key, event.target.value)}
              />
            </label>
          );
        }

        if (field.widget === "select") {
          return (
            <label key={field.key}>
              <span>{field.label}</span>
              <select
                value={String(currentValue ?? "")}
                onChange={(event) => handleFieldChange(field.key, event.target.value)}
              >
                <option value="">Select {field.label}</option>
                {(field.options ?? []).map((option) => (
                  <option key={option} value={option}>
                    {option}
                  </option>
                ))}
              </select>
            </label>
          );
        }

        if (field.widget === "multiselect") {
          return (
            <label key={field.key}>
              <span>{field.label}</span>
              <select
                multiple
                value={Array.isArray(currentValue) ? currentValue.map(String) : []}
                onChange={(event) =>
                  handleFieldChange(
                    field.key,
                    Array.from(event.target.selectedOptions).map((option) => option.value),
                  )
                }
              >
                {(field.options ?? []).map((option) => (
                  <option key={option} value={option}>
                    {option}
                  </option>
                ))}
              </select>
            </label>
          );
        }

        if (field.widget === "checkbox") {
          return (
            <label key={field.key}>
              <input
                checked={Boolean(currentValue)}
                type="checkbox"
                onChange={(event) => handleFieldChange(field.key, event.target.checked)}
              />
              <span>{field.label}</span>
            </label>
          );
        }

        return (
          <label key={field.key}>
            <span>{field.label}</span>
            <input
              type={field.inputType}
              value={String(getFieldValue(currentValue))}
              onChange={(event) =>
                handleFieldChange(
                  field.key,
                  field.widget === "tags"
                    ? event.target.value
                        .split(",")
                        .map((part) => part.trim())
                        .filter(Boolean)
                    : field.inputType === "number"
                      ? Number(event.target.value)
                      : event.target.value,
                )
              }
            />
          </label>
        );
      })}
      <button disabled={isLoading} type="submit">
        {isLoading ? "Saving..." : "Save InventoryItem"}
      </button>
    </form>
  );
}

export default InventoryItemForm;
",
      "kind": "form",
