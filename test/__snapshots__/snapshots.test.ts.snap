    {
      "action": "create",
      "content": "import React, { useEffect, useState } from "react";
import {
  createInventoryItem,
  deleteInventoryItem,
  getInventoryItem,
  listInventoryItems,
  updateInventoryItem,
} from "../api/inventory-item.api";

export function useInventoryItem() {
  const [items, setItems] = useState([]);
  const [item, setItem] = useState(null);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState(null);

  const refresh = async () => {
    setIsLoading(true);
    setError(null);

    try {
      const nextItems = await listInventoryItems();
      setItems(nextItems);
      return nextItems;
    } catch (nextError) {
      setError(nextError instanceof Error ? nextError.message : "Unknown error");
      throw nextError;
    } finally {
      setIsLoading(false);
    }
  };

  useEffect(() => {
    void refresh();
  }, []);

  const loadItem = async (id) => {
    setIsLoading(true);
    setError(null);

    try {
      const nextItem = await getInventoryItem(id);
      setItem(nextItem);
      return nextItem;
    } catch (nextError) {
      setError(nextError instanceof Error ? nextError.message : "Unknown error");
      throw nextError;
    } finally {
      setIsLoading(false);
    }
  };

  const createItem = async (payload) => {
    setIsLoading(true);
    setError(null);

    try {
      const created = await createInventoryItem(payload);
      setItems((current) => [created, ...current]);
      setItem(created);
      return created;
    } catch (nextError) {
      setError(nextError instanceof Error ? nextError.message : "Unknown error");
      throw nextError;
    } finally {
      setIsLoading(false);
    }
  };

  const updateItem = async (id, payload) => {
    setIsLoading(true);
    setError(null);

    try {
      const updated = await updateInventoryItem(id, payload);
      setItems((current) => current.map((entry) => (entry._id === updated._id ? updated : entry)));
      setItem(updated);
      return updated;
    } catch (nextError) {
      setError(nextError instanceof Error ? nextError.message : "Unknown error");
      throw nextError;
    } finally {
      setIsLoading(false);
    }
  };

  const removeItem = async (id) => {
    setIsLoading(true);
    setError(null);

    try {
      await deleteInventoryItem(id);
      setItems((current) => current.filter((entry) => entry._id !== id));
      setItem((current) => (current?._id === id ? null : current));
    } catch (nextError) {
      setError(nextError instanceof Error ? nextError.message : "Unknown error");
      throw nextError;
    } finally {
      setIsLoading(false);
    }
  };

  return {
    items,
    item,
    isLoading,
    error,
    refresh,
    loadItem,
    createItem,
    updateItem,
    deleteItem: removeItem,
  };
}

export default useInventoryItem;
",
      "kind": "hook",
