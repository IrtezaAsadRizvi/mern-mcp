    {
      "action": "create",
      "content": "export interface Order {
  _id?: string;
  status: "draft" | "placed" | "shipped";
  customer: string;
  createdAt?: string;
  updatedAt?: string;
}

export interface OrderFormValues {
  status: "draft" | "placed" | "shipped";
  customer: string;
}

export interface OrderFieldConfig {
  key: keyof OrderFormValues;
  label: string;
  required: boolean;
  widget: string;
  inputType: string;
  isArray: boolean;
  options?: string[];
}

export const orderFieldConfig: OrderFieldConfig[] = [
  {
    key: "status",
    label: "Status",
    required: true,
    widget: "select",
    inputType: "text",
    isArray: false,
    options: ["draft", "placed", "shipped"],
  },
  {
    key: "customer",
    label: "Customer",
    required: true,
    widget: "text",
    inputType: "text",
    isArray: false,
    options: undefined,
  },
];

export const orderInitialValues: OrderFormValues = {
  status: "draft",
  customer: "",
};
",
      "kind": "types",
      "path": "client/src/types/order.types.ts",
      "reason": null,
    },
    {
      "action": "create",
      "content": "import { createAsyncThunk, createSlice } from "@reduxjs/toolkit";
import type { Order, OrderFormValues } from "../types/order.types";

const BASE_URL = "/api/orders";

async function request(path: string, init: RequestInit = {}) {
  const response = await fetch(\`\${BASE_URL}\${path}\`, {
    headers: {
      "Content-Type": "application/json",
      ...(init.headers ?? {}),
    },
    ...init,
  });

  if (!response.ok) {
    throw new Error(\`Request failed with status \${response.status}\`);
  }

  if (response.status === 204) {
    return null;
  }

  return response.json();
}

export async function listOrders(): Promise<Order[]> {
  return request("/");
}

export async function getOrder(id: string): Promise<Order> {
  return request(\`/\${id}\`);
}

export async function createOrder(payload: OrderFormValues): Promise<Order> {
  return request("/", {
    method: "POST",
    body: JSON.stringify(payload),
  });
}

export async function updateOrder(id: string, payload: OrderFormValues): Promise<Order> {
  return request(\`/\${id}\`, {
    method: "PUT",
    body: JSON.stringify(payload),
  });
}

export async function deleteOrder(id: string): Promise<void> {
  await request(\`/\${id}\`, {
    method: "DELETE",
  });
}

export interface OrderState {
  items: Order[];
  item: Order | null;
  isLoading: boolean;
  error: string | null;
}

export const orderStoreKey = "orders";

export const initialOrderState: OrderState = {
  items: [],
  item: null,
  isLoading: false,
  error: null,
};

export const fetchOrdersThunk = createAsyncThunk("orders/fetchAll", async () => listOrders());

export const fetchOrderThunk = createAsyncThunk("orders/fetchOne", async (id: string) =>
  getOrder(id),
);

export const createOrderThunk = createAsyncThunk(
  "orders/create",
  async (payload: OrderFormValues) => createOrder(payload),
);

export const updateOrderThunk = createAsyncThunk(
  "orders/update",
  async (params: { id: string; payload: OrderFormValues }) =>
    updateOrder(params.id, params.payload),
);

export const deleteOrderThunk = createAsyncThunk("orders/delete", async (id: string) => {
  await deleteOrder(id);
  return id;
});

const orderSlice = createSlice({
  name: "orders",
  initialState: initialOrderState,
  reducers: {},
  extraReducers: (builder) => {
    builder
      .addCase(fetchOrdersThunk.pending, (state) => {
        state.isLoading = true;
        state.error = null;
      })
      .addCase(fetchOrdersThunk.fulfilled, (state, action) => {
        state.isLoading = false;
        state.items = action.payload;
      })
      .addCase(fetchOrdersThunk.rejected, (state, action) => {
        state.isLoading = false;
        state.error = action.error.message ?? "Unknown error";
      })
      .addCase(fetchOrderThunk.fulfilled, (state, action) => {
        state.item = action.payload;
      })
      .addCase(createOrderThunk.fulfilled, (state, action) => {
        state.items = [action.payload, ...state.items];
        state.item = action.payload;
      })
      .addCase(updateOrderThunk.fulfilled, (state, action) => {
        state.items = state.items.map((entry) =>
          entry._id === action.payload._id ? action.payload : entry,
        );
        state.item = action.payload;
      })
      .addCase(deleteOrderThunk.fulfilled, (state, action) => {
        state.items = state.items.filter((entry) => entry._id !== action.payload);
        state.item = state.item?._id === action.payload ? null : state.item;
      });
  },
});

export const orderReducer = orderSlice.reducer;
",
      "kind": "api",
      "path": "client/src/api/order.api.ts",
      "reason": null,
    },
    {
      "action": "create",
      "content": "import React, { useEffect } from "react";
import { useDispatch, useSelector } from "react-redux";
import type { OrderFormValues } from "../types/order.types";
import {
  createOrderThunk,
  deleteOrderThunk,
  fetchOrderThunk,
  fetchOrdersThunk,
  initialOrderState,
  updateOrderThunk,
  orderStoreKey,
} from "../api/order.api";

export function useOrder() {
  const dispatch = useDispatch<any>();
  const state = useSelector((rootState: Record<string, typeof initialOrderState>) => {
    return rootState[orderStoreKey] ?? initialOrderState;
  });

  useEffect(() => {
    void dispatch(fetchOrdersThunk());
  }, [dispatch]);

  return {
    items: state.items,
    item: state.item,
    isLoading: state.isLoading,
    error: state.error,
    refresh: () => dispatch(fetchOrdersThunk()).unwrap(),
    loadItem: (id: string) => dispatch(fetchOrderThunk(id)).unwrap(),
    createItem: (payload: OrderFormValues) => dispatch(createOrderThunk(payload)).unwrap(),
    updateItem: (id: string, payload: OrderFormValues) =>
      dispatch(updateOrderThunk({ id, payload })).unwrap(),
    deleteItem: (id: string) => dispatch(deleteOrderThunk(id)).unwrap(),
  };
}

export default useOrder;
",
      "kind": "hook",
      "path": "client/src/hooks/useOrder.ts",
      "reason": null,
    },
    {
      "action": "create",
      "content": "import React, { useEffect, useState } from "react";
import type { Order, OrderFormValues } from "../types/order.types";
import { orderFieldConfig, orderInitialValues } from "../types/order.types";
import { useOrder } from "../hooks/useOrder";

export interface OrderFormProps {
  value?: Order | null;
  onSuccess?: (item: Order) => void;
}

function getFieldValue(value: unknown) {
  if (Array.isArray(value)) {
    return value.join(", ");
  }

  return value ?? "";
}

export function OrderForm({ value, onSuccess }: OrderFormProps) {
  const { createItem, updateItem, isLoading, error } = useOrder();
  const [formValues, setFormValues] = useState<OrderFormValues>(() => ({
    ...orderInitialValues,
    ...(value ?? {}),
  }));

  useEffect(() => {
    setFormValues({
      ...orderInitialValues,
      ...(value ?? {}),
    });
  }, [value]);

  const handleFieldChange = (fieldKey: string, nextValue: unknown) => {
    setFormValues((current) => ({
      ...current,
      [fieldKey]: nextValue,
    }));
  };

  const handleSubmit = async (event: React.FormEvent<HTMLFormElement>) => {
    event.preventDefault();

    const saved = value?._id
      ? await updateItem(value._id, formValues)
      : await createItem(formValues);

    if (!value?._id) {
      setFormValues({ ...orderInitialValues });
    }

    onSuccess?.(saved);
  };

  return (
    <form onSubmit={handleSubmit}>
      <h2>{value?._id ? "Edit Order" : "Create Order"}</h2>
      {error ? <p role="alert">{String(error)}</p> : null}
      {orderFieldConfig.map((field) => {
        const currentValue = formValues[field.key];

        if (field.widget === "textarea") {
          return (
            <label key={field.key}>
              <span>{field.label}</span>
              <textarea
                value={String(getFieldValue(currentValue))}
                onChange={(event) => handleFieldChange(field.key, event.target.value)}
              />
            </label>
          );
        }

        if (field.widget === "select") {
          return (
            <label key={field.key}>
              <span>{field.label}</span>
              <select
                value={String(currentValue ?? "")}
                onChange={(event) => handleFieldChange(field.key, event.target.value)}
              >
                <option value="">Select {field.label}</option>
                {(field.options ?? []).map((option) => (
                  <option key={option} value={option}>
                    {option}
                  </option>
                ))}
              </select>
            </label>
          );
        }

        if (field.widget === "multiselect") {
          return (
            <label key={field.key}>
              <span>{field.label}</span>
              <select
                multiple
                value={Array.isArray(currentValue) ? currentValue.map(String) : []}
                onChange={(event) =>
                  handleFieldChange(
                    field.key,
                    Array.from(event.target.selectedOptions).map((option) => option.value),
                  )
                }
              >
                {(field.options ?? []).map((option) => (
                  <option key={option} value={option}>
                    {option}
                  </option>
                ))}
              </select>
            </label>
          );
        }

        if (field.widget === "checkbox") {
          return (
            <label key={field.key}>
              <input
                checked={Boolean(currentValue)}
                type="checkbox"
                onChange={(event) => handleFieldChange(field.key, event.target.checked)}
              />
              <span>{field.label}</span>
            </label>
          );
        }

        return (
          <label key={field.key}>
            <span>{field.label}</span>
            <input
              type={field.inputType}
              value={String(getFieldValue(currentValue))}
              onChange={(event) =>
                handleFieldChange(
                  field.key,
                  field.widget === "tags"
                    ? event.target.value
                        .split(",")
                        .map((part) => part.trim())
                        .filter(Boolean)
                    : field.inputType === "number"
                      ? Number(event.target.value)
                      : event.target.value,
                )
              }
            />
          </label>
        );
      })}
      <button disabled={isLoading} type="submit">
        {isLoading ? "Saving..." : "Save Order"}
      </button>
    </form>
  );
}

export default OrderForm;
",
      "kind": "form",
      "path": "client/src/components/OrderForm.tsx",
      "reason": null,
    },
    {
      "action": "create",
      "content": "import React from "react";
import type { Order } from "../types/order.types";
import { orderFieldConfig } from "../types/order.types";
import { useOrder } from "../hooks/useOrder";

function renderCellValue(value: unknown) {
  if (Array.isArray(value)) {
    return value.join(", ");
  }

  if (typeof value === "boolean") {
    return value ? "Yes" : "No";
  }

  return value ? String(value) : "—";
}

export interface OrderListProps {
  onSelect?: (item: Order) => void;
}

export function OrderList({ onSelect }: OrderListProps) {
  const { items, deleteItem, isLoading, error } = useOrder();

  if (isLoading) {
    return <p>Loading orders...</p>;
  }

  return (
    <section>
      <h2>Orders</h2>
      {error ? <p role="alert">{String(error)}</p> : null}
      {items.length === 0 ? <p>No orders found.</p> : null}
      {items.length > 0 ? (
        <table>
          <thead>
            <tr>
              {orderFieldConfig.map((field) => (
                <th key={field.key}>{field.label}</th>
              ))}
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {items.map((item) => (
              <tr key={item._id ?? JSON.stringify(item)}>
                {orderFieldConfig.map((field) => (
                  <td key={field.key}>{renderCellValue(item[field.key])}</td>
                ))}
                <td>
                  <button type="button" onClick={() => onSelect?.(item)}>
                    View
                  </button>
                  {item._id ? (
                    <button type="button" onClick={() => deleteItem(item._id)}>
                      Delete
                    </button>
                  ) : null}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : null}
    </section>
  );
}

export default OrderList;
",
      "kind": "list",
      "path": "client/src/components/OrderList.tsx",
