    {
      "action": "create",
      "content": "import React from "react";
import { inventoryItemFieldConfig } from "../types/inventory-item.types";
import { useInventoryItem } from "../hooks/useInventoryItem";

function renderCellValue(value) {
  if (Array.isArray(value)) {
    return value.join(", ");
  }

  if (typeof value === "boolean") {
    return value ? "Yes" : "No";
  }

  return value ? String(value) : "—";
}

export function InventoryItemList({ onSelect }) {
  const { items, deleteItem, isLoading, error } = useInventoryItem();

  if (isLoading) {
    return <p>Loading inventoryItems...</p>;
  }

  return (
    <section>
      <h2>InventoryItems</h2>
      {error ? <p role="alert">{String(error)}</p> : null}
      {items.length === 0 ? <p>No inventoryItems found.</p> : null}
      {items.length > 0 ? (
        <table>
          <thead>
            <tr>
              {inventoryItemFieldConfig.map((field) => (
                <th key={field.key}>{field.label}</th>
              ))}
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {items.map((item) => (
              <tr key={item._id ?? JSON.stringify(item)}>
                {inventoryItemFieldConfig.map((field) => (
                  <td key={field.key}>{renderCellValue(item[field.key])}</td>
                ))}
                <td>
                  <button type="button" onClick={() => onSelect?.(item)}>
                    View
                  </button>
                  {item._id ? (
                    <button type="button" onClick={() => deleteItem(item._id)}>
                      Delete
                    </button>
                  ) : null}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : null}
    </section>
  );
}

export default InventoryItemList;
",
      "kind": "list",
      "path": "client/components/InventoryItemList.jsx",
      "reason": null,
    },
    {
      "action": "create",
      "content": "import React, { useEffect, useState } from "react";
import { inventoryItemFieldConfig } from "../types/inventory-item.types";
import { useInventoryItem } from "../hooks/useInventoryItem";

function renderFieldValue(value) {
  if (Array.isArray(value)) {
    return value.join(", ");
  }

  if (typeof value === "boolean") {
    return value ? "Yes" : "No";
  }

  return value ? String(value) : "—";
}

export function InventoryItemDetail({ id, item, onEdit }) {
  const { loadItem, isLoading, error } = useInventoryItem();
  const [resolvedItem, setResolvedItem] = useState(item ?? null);

  useEffect(() => {
    setResolvedItem(item ?? null);
  }, [item]);

  useEffect(() => {
    if (!id) {
      return;
    }

    void loadItem(id).then((nextItem) => {
      setResolvedItem(nextItem);
    });
  }, [id]);

  if (!resolvedItem && isLoading) {
    return <p>Loading InventoryItem...</p>;
  }

  if (!resolvedItem) {
    return <p>No InventoryItem selected.</p>;
  }

  return (
    <section>
      <h2>InventoryItem details</h2>
      {error ? <p role="alert">{String(error)}</p> : null}
      <dl>
        {inventoryItemFieldConfig.map((field) => (
          <React.Fragment key={field.key}>
            <dt>{field.label}</dt>
            <dd>{renderFieldValue(resolvedItem[field.key])}</dd>
          </React.Fragment>
        ))}
      </dl>
      <button type="button" onClick={() => onEdit?.(resolvedItem)}>
        Edit
      </button>
    </section>
  );
}

export default InventoryItemDetail;
