export async function listInventoryItems() {
  return InventoryItemModel.find().lean();
}

export async function getInventoryItemById(id) {
  return InventoryItemModel.findById(id).lean();
}

export async function createInventoryItem(payload) {
  const created = await InventoryItemModel.create(payload);
  return created.toObject();
}

export async function updateInventoryItem(id, payload) {
  return InventoryItemModel.findByIdAndUpdate(id, payload, {
    new: true,
    runValidators: true,
  }).lean();
}

export async function deleteInventoryItem(id) {
  return InventoryItemModel.findByIdAndDelete(id).lean();
}
