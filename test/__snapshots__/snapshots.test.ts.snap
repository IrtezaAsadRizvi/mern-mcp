      "action": "create",
      "content": "import { OrderModel, type OrderDocument } from "../models/order.model";

export type OrderPayload = Partial<OrderDocument>;

export async function listOrders() {
  return OrderModel.find().lean();
}

export async function getOrderById(id: string) {
  return OrderModel.findById(id).lean();
}

export async function createOrder(payload: OrderPayload) {
  const created = await OrderModel.create(payload);
  return created.toObject();
}

export async function updateOrder(id: string, payload: OrderPayload) {
  return OrderModel.findByIdAndUpdate(id, payload, {
    new: true,
    runValidators: true,
  }).lean();
}

export async function deleteOrder(id: string) {
  return OrderModel.findByIdAndDelete(id).lean();
}
