    {
      "action": "create",
      "content": "import type { Request, Response } from "express";

import * as orderService from "../services/order.service";

export async function listOrders(_request: Request, response: Response) {
  const items = await orderService.listOrders();
  response.json(items);
}

export async function getOrder(request: Request, response: Response) {
  const item = await orderService.getOrderById(request.params.id);

  if (!item) {
    response.status(404).json({
      message: "Order not found",
    });
    return;
  }

  response.json(item);
}

export async function createOrder(request: Request, response: Response) {
  const created = await orderService.createOrder(request.body);
  response.status(201).json(created);
}

export async function updateOrder(request: Request, response: Response) {
  const updated = await orderService.updateOrder(request.params.id, request.body);

  if (!updated) {
    response.status(404).json({
      message: "Order not found",
    });
    return;
  }

  response.json(updated);
}

export async function deleteOrder(request: Request, response: Response) {
  const deleted = await orderService.deleteOrder(request.params.id);

  if (!deleted) {
    response.status(404).json({
      message: "Order not found",
    });
    return;
  }

  response.status(204).send();
}
