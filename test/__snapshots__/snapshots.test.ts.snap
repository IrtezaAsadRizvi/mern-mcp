      "action": "create",
      "content": "import * as inventoryItemService from "../services/inventory-item.service";

export async function listInventoryItems(_request, response) {
  const items = await inventoryItemService.listInventoryItems();
  response.json(items);
}

export async function getInventoryItem(request, response) {
  const item = await inventoryItemService.getInventoryItemById(request.params.id);

  if (!item) {
    response.status(404).json({
      message: "InventoryItem not found",
    });
    return;
  }

  response.json(item);
}

export async function createInventoryItem(request, response) {
  const created = await inventoryItemService.createInventoryItem(request.body);
  response.status(201).json(created);
}

export async function updateInventoryItem(request, response) {
  const updated = await inventoryItemService.updateInventoryItem(request.params.id, request.body);

  if (!updated) {
    response.status(404).json({
      message: "InventoryItem not found",
    });
    return;
  }

  response.json(updated);
}

export async function deleteInventoryItem(request, response) {
  const deleted = await inventoryItemService.deleteInventoryItem(request.params.id);

  if (!deleted) {
    response.status(404).json({
      message: "InventoryItem not found",
    });
    return;
  }

  response.status(204).send();
}
